# ══════════════════════════════════════════════════════════════════════════════
# Servidor MCP Centralizado — AmorSaúde
# Copie este arquivo para .env e preencha com os valores reais.
# ══════════════════════════════════════════════════════════════════════════════

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
MODEL_EVALUATOR="gpt-5.5"

# ── AWS / Athena ──────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"
ATHENA_DATABASE="pdgt_amorsaude_inteligencia"
ATHENA_S3_STAGING_DIR="s3://seu-bucket/athena-results/"
ATHENA_MAX_ROWS=5000

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY="pcsk_..."

# Índices
PINECONE_INDEX_CFM="qualidade-conformidade-2"
PINECONE_INDEX_POP="pops-nr-2"
PINECONE_INDEX_HAS="rag-agente-hipertensao"
PINECONE_RAG_INDEX="rag-agente-cirurgias"

# Namespaces
PINECONE_NAMESPACE_CFM="cfm_2153_2016"
PINECONE_NAMESPACE_REGRAS="regras_negocio_prontuario"
PINECONE_NAMESPACE_RDC="rdc_anvisa"
PINECONE_NAMESPACE_HAS="documento_hipertensao"
PINECONE_NS_TREINAMENTO="treinamento_ia_catarata"
PINECONE_NS_VOCABULARIO="catarata_vocabulario_expandido"
PINECONE_NS_PRONTUARIOS="prontuarios_pacientes"

# ── Servidor MCP ──────────────────────────────────────────────────────────────
MCP_SERVER_PORT=8000
